@model List<Tripify.WebUI.Dtos.CategoryDtos.ResultCategoryDto>
@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

<div class="page-header mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title h4 mb-1">Kategori Listesi</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Kategoriler</li>
            </ol>
        </nav>
    </div>
    <a href="/AdminCategory/CreateCategory" class="btn btn-primary d-flex align-items-center gap-2" style="border-radius:10px;">
        <i class="bi bi-plus-lg"></i> Yeni Kategori Ekle
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-tags text-secondary"></i>
            <span class="fw-semibold">Kayıtlı Kategoriler</span>
            <span class="badge bg-light text-muted border">@Model?.Count ?? 0 kayıt</span>
        </div>
    </div>
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-4 text-center text-muted">
                <i class="bi bi-emoji-neutral mb-2" style="font-size:2rem;"></i>
                <p class="mb-1">Henüz kayıtlı bir kategori bulunmuyor.</p>
                <a href="/AdminCategory/CreateCategory" class="btn btn-sm btn-primary mt-2">İlk kategoriyi ekle</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>İkon</th>
                            <th>Kategori Adı</th>
                            <th>Durum</th>
                            <th style="width:120px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                                    {
                                        <img src="@item.IconUrl" alt="@item.CategoryName" style="width:32px;height:32px;object-fit:contain;" />
                                    }
                                    else
                                    {
                                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-light border" style="width:32px;height:32px;">
                                            <i class="bi bi-tag text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td class="fw-semibold">@item.CategoryName</td>
                                <td>
                                    @if (item.IsStatus)
                                    {
                                        <span class="badge bg-success-subtle text-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Pasif</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="/AdminCategory/UpdateCategory/@item.CategoryId" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a href="/AdminCategory/RemoveCategory/@item.CategoryId" class="btn btn-sm btn-danger"
                                           onclick="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

