@model Tripify.WebUI.Dtos.CategoryDtos.GetCategoryByIdDto
@{
    ViewData["Title"] = "Kategori Güncelle";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

<div class="page-header mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title h4 mb-1">Kategori Güncelle</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item"><a href="/AdminCategory/CategoryList">Kategoriler</a></li>
                <li class="breadcrumb-item active" aria-current="page">Güncelle</li>
            </ol>
        </nav>
    </div>
    <a href="/AdminCategory/CategoryList" class="btn btn-outline-secondary d-flex align-items-center gap-2" style="border-radius:10px;">
        <i class="bi bi-arrow-left"></i> Listeye Dön
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="CategoryId" />

            <div class="mb-3">
                <label asp-for="CategoryName" class="form-label fw-semibold">Kategori Adı</label>
                <input asp-for="CategoryName" class="form-control" />
                <span asp-validation-for="CategoryName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="IconUrl" class="form-label fw-semibold">İkon URL</label>
                <input asp-for="IconUrl" class="form-control" />
                <span asp-validation-for="IconUrl" class="text-danger small"></span>
            </div>

            <div class="form-check form-switch mb-4">
                <input class="form-check-input" type="checkbox" id="isStatus" asp-for="IsStatus">
                <label class="form-check-label" for="isStatus">Aktif Olsun</label>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <a href="/AdminCategory/CategoryList" class="btn btn-outline-secondary">İptal</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Güncelle
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

