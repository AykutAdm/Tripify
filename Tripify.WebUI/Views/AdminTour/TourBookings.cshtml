@model List<ResultBookingDto>
@{
    ViewData["Title"] = "Tur Rezervasyonları";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
    var tourTitle = ViewBag.TourTitle as string ?? "Tur";
    var tourId = ViewBag.TourId as string ?? "";
}

<div class="page-header mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title h4 mb-1">@tourTitle - Rezervasyon Yapan Müşteriler</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/AdminTour/TourList">Turlar</a></li>
                <li class="breadcrumb-item active" aria-current="page">Rezervasyonlar</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        @if (!string.IsNullOrEmpty(tourId))
        {
            <a href="/AdminTour/DownloadTourBookingsPdf/@tourId" class="btn btn-danger btn-sm" title="Rezervasyon listesini PDF olarak indir">
                <i class="bi bi-file-pdf me-1"></i> PDF İndir
            </a>
        }
        <a href="/AdminTour/TourList" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Tur Listesine Dön
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-people text-secondary"></i>
            <span class="fw-semibold">Bu tura rezervasyon yapan müşteriler</span>
            <span class="badge bg-light text-muted border">@(Model?.Count ?? 0) kayıt</span>
        </div>
    </div>
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-4 text-center text-muted">
                <i class="bi bi-person-x mb-2" style="font-size:2rem;"></i>
                <p class="mb-1">Bu tura henüz rezervasyon yapılmamış.</p>
                <a href="/AdminTour/TourList" class="btn btn-sm btn-primary mt-2">Tur Listesine Dön</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Müşteri Adı</th>
                            <th>E-posta</th>
                            <th>Telefon</th>
                            <th>Tarih Aralığı</th>
                            <th>Kişi Sayısı</th>
                            <th>Toplam Fiyat</th>
                            <th>Durum</th>
                            <th>Rezervasyon Tarihi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderByDescending(x => x.BookingDate))
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.FirstName @item.LastName</div>
                                    @if (!string.IsNullOrEmpty(item.Title))
                                    {
                                        <div class="text-muted small">@item.Title</div>
                                    }
                                </td>
                                <td>@item.Email</td>
                                <td>@item.Phone</td>
                                <td>
                                    <div class="small">
                                        @item.CheckInDate.ToString("dd.MM.yyyy") - @item.CheckOutDate.ToString("dd.MM.yyyy")
                                    </div>
                                </td>
                                <td>@item.NumberOfPeople</td>
                                <td>@item.TotalPrice.ToString("N2") ₺</td>
                                <td>
                                    @{
                                        var status = item.Status ?? "Pending";
                                        string badgeClass = status switch
                                        {
                                            "Approved" => "badge bg-success-subtle text-success",
                                            "Rejected" => "badge bg-danger-subtle text-danger",
                                            _ => "badge bg-warning-subtle text-warning"
                                        };
                                        string statusText = status switch
                                        {
                                            "Approved" => "Onaylandı",
                                            "Rejected" => "Reddedildi",
                                            _ => "Beklemede"
                                        };
                                    }
                                    <span class="@badgeClass">@statusText</span>
                                </td>
                                <td class="text-muted small">@item.BookingDate.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
