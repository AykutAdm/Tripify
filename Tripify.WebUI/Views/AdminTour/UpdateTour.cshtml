                                    <div class="field-hint"><i class="bi bi-info-circle me-1"></i>Kişi başı fiyat (TL)</div>
                                    <span asp-validation-for="Price" class="text-danger-field"><i class="bi bi-exclamation-circle"></i><span></span></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>


                <div class="form-section">
                    <div class="section-header">
                        <div class="section-icon purple"><i class="bi bi-image"></i></div>
