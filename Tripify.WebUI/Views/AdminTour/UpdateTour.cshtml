                    </div>
                </div>
            </div>

            <!-- TUR DETAYLARI -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon amber"><i class="bi bi-calendar3"></i></div>
                    <div>
                        <div class="section-title">Tur Detaylar²</div>
                        <div class="section-subtitle">Tarih, s³re ve kapasite bilgileri</div>
                    </div>
                </div>
                <div class="section-body">
                    <div class="row g-3">
                        <!-- Tur Tarihi -->
                        <div class="col-md-6">
                            <div class="field-group">
                                <label asp-for="TourDate" class="field-label">
