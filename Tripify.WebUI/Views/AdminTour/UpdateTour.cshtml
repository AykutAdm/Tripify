    <a href="/AdminTour/TourList/" class="btn btn-outline-secondary d-flex align-items-center gap-2" style="border-radius:10px;font-size:.875rem;font-weight:500;padding:.55rem 1.1rem;">
        <i class="bi bi-arrow-left"></i> Tur Listesine D÷n
    </a>
</div>

<form method="post" id="createTourForm" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="TourId" />
    <div class="form-grid">

        <!-- =======================================
             LEFT COLUMN Ś ANA FORM
        ======================================== -->
        <div class="form-main">

            <!-- TEMEL B▌LG▌LER -->
            <div class="form-section">
                <div class="section-header">
