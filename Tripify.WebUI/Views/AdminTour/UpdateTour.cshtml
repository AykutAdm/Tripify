@model GetTourByIdDto
@{
    ViewData["Title"] = "UpdateTour";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}


@section Styles {
    <style>

        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .page-title {
            font-family: var(--font-display);
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -.03em;
            line-height: 1;
        }

        .breadcrumb {
            margin: 0;
            padding: 0;
            background: none;
        }

        .breadcrumb-item {
            font-size: .8rem;
        }

        .create-tour-page .breadcrumb-item a {
            color: var(--accent-strong);
            text-decoration: none;
        }

        .create-tour-page .breadcrumb-item.active {
            color: var(--text-muted);
        }


        .form-grid {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 1.5rem;
            align-items: start;
        }


        .create-tour-page .form-section {
            background: linear-gradient(135deg, rgba(18,18,24,.6), rgba(14,14,20,.65));
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 16px 40px rgba(0,0,0,.2);
            margin-bottom: 1.5rem;
        }

            .create-tour-page .form-section:last-child {
                margin-bottom: 0;
            }

        .create-tour-page .section-header {
            display: flex;
            align-items: center;
            gap: .85rem;
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,.06);
            background: rgba(24,24,32,.5);
        }

        .create-tour-page .section-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: grid;
            place-items: center;
            font-size: 1rem;
            flex-shrink: 0;
        }

            .create-tour-page .section-icon.blue {
                background: rgba(56,189,248,.2);
                color: #38bdf8;
            }

            .create-tour-page .section-icon.amber {
                background: rgba(251,191,36,.2);
                color: #fbbf24;
            }

            .create-tour-page .section-icon.green {
                background: rgba(34,197,94,.2);
                color: #4ade80;
            }

            .create-tour-page .section-icon.purple {
                background: rgba(139,92,246,.2);
                color: #a78bfa;
            }

        .create-tour-page .section-title {
            font-family: var(--font-display);
            font-weight: 700;
            font-size: .95rem;
            color: #ffffff;
        }

        .create-tour-page .section-subtitle {
            font-size: .75rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .create-tour-page .section-body {
            padding: 1.5rem;
        }


        .field-group {
            margin-bottom: 1.25rem;
        }

            .field-group:last-child {
                margin-bottom: 0;
            }

        .field-label {
            display: flex;
            align-items: center;
            gap: .35rem;
            font-size: .78rem;
            font-weight: 600;
            color: #4a5568;
            margin-bottom: .45rem;
            letter-spacing: .01em;
        }

            .field-label .required {
                color: #e53e3e;
                font-size: .85rem;
                line-height: 1;
            }

        .field-hint {
            font-size: .73rem;
            color: #a0aec0;
            margin-top: .35rem;
        }

        .form-control, .form-select {
            border: 1.5px solid #1f2937;
            border-radius: 9px;
            padding: .6rem .875rem;
            font-size: .875rem;
            font-family: var(--font-body);
            color: var(--text-primary);
            background: #020617;
            transition: border-color .15s, box-shadow .15s, background .15s;
            width: 100%;
        }

            .form-control:focus, .form-select:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 3px rgba(37,99,235,.1);
                outline: none;
            }

            .form-control.is-invalid, .form-select.is-invalid {
                border-color: #e53e3e;
                box-shadow: none;
            }

                .form-control.is-invalid:focus, .form-select.is-invalid:focus {
                    box-shadow: 0 0 0 3px rgba(229,62,62,.1);
                }

        textarea.form-control {
            resize: vertical;
            min-height: 110px;
            line-height: 1.6;
        }

        .input-with-icon {
            position: relative;
        }

            .input-with-icon .input-icon {
                position: absolute;
                left: .875rem;
                top: 50%;
                transform: translateY(-50%);
                color: #a0aec0;
                font-size: .9rem;
                pointer-events: none;
            }

            .input-with-icon .form-control {
                padding-left: 2.4rem;
            }

        .char-counter {
            font-size: .72rem;
            color: #a0aec0;
            text-align: right;
            margin-top: .3rem;
        }

            .char-counter.warn {
                color: #d97706;
            }

            .char-counter.danger {
                color: #e53e3e;
            }


        .duration-builder {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .75rem;
        }

        .duration-unit {
            display: flex;
            flex-direction: column;
            gap: .4rem;
        }

            .duration-unit label {
                font-size: .73rem;
                font-weight: 600;
                color: #718096;
                text-transform: uppercase;
                letter-spacing: .06em;
            }


        .create-tour-page .image-upload-zone {
            border: 2px dashed rgba(255,255,255,.2);
            border-radius: 12px;
            padding: 2rem 1.5rem;
            text-align: center;
            cursor: pointer;
            transition: all .2s;
            background: rgba(24,24,32,.4);
            position: relative;
        }

            .create-tour-page .image-upload-zone:hover,
            .create-tour-page .image-upload-zone.dragover {
                border-color: var(--accent-strong);
                background: rgba(56,189,248,.1);
            }

        .image-upload-zone input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
            height: 100%;
        }

        .create-tour-page .upload-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: rgba(56,189,248,.2);
            display: grid;
            place-items: center;
            margin: 0 auto .75rem;
            font-size: 1.3rem;
            color: #38bdf8;
            transition: transform .2s;
        }

        .create-tour-page .image-upload-zone:hover .upload-icon {
            transform: translateY(-2px);
        }

        .create-tour-page .upload-title {
            font-weight: 600;
            font-size: .9rem;
            color: #f1f5f9;
            margin-bottom: .35rem;
        }

        .create-tour-page .upload-sub {
            font-size: .76rem;
            color: var(--text-muted);
        }

        .create-tour-page .image-preview-box {
            display: none;
            position: relative;
            border-radius: 12px;
            overflow: hidden;
            background: rgba(24,24,32,.6);
            aspect-ratio: 16/9;
            border: 1px solid rgba(255,255,255,.06);
        }

        .image-preview-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .preview-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,.45);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity .2s;
        }

        .image-preview-box:hover .preview-overlay {
            opacity: 1;
        }

        .create-tour-page .preview-remove {
            background: rgba(248,113,113,.9);
            border: none;
            border-radius: 8px;
            padding: .45rem .9rem;
            font-size: .8rem;
            font-weight: 600;
            cursor: pointer;
            color: #fff;
            display: flex;
            align-items: center;
            gap: .4rem;
        }


        .create-tour-page .url-preview-thumb {
            width: 100%;
            height: 140px;
            object-fit: cover;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,.1);
            display: none;
            margin-top: .65rem;
        }

        .create-tour-page .create-tour-page .stepper {
            display: flex;
            align-items: center;
            gap: 0;
            border: 1px solid rgba(255,255,255,.1);
            border-radius: 10px;
            overflow: hidden;
            width: 100%;
        }

        .create-tour-page .create-tour-page .stepper-btn {
            width: 42px;
            height: 42px;
            background: rgba(255,255,255,.05);
            border: none;
            cursor: pointer;
            font-size: 1.1rem;
            color: #94a3b8;
            transition: all .2s;
            flex-shrink: 0;
            display: grid;
            place-items: center;
        }

        .create-tour-page .stepper-btn:hover {
            background: rgba(56,189,248,.15);
            color: #38bdf8;
        }

        .create-tour-page .stepper input {
            flex: 1;
            border: none;
            text-align: center;
            font-size: .9rem;
            font-weight: 600;
            color: #ffffff;
            font-family: var(--font-display);
            min-width: 0;
            padding: 0;
            background: transparent;
        }

            .create-tour-page .stepper input:focus {
                outline: none;
            }


        .sidebar-panel {
            position: sticky;
            top: 1.5rem;
        }


        .create-tour-page .status-option {
            display: flex;
            align-items: center;
            gap: .9rem;
            padding: .9rem 1rem;
            border: 1px solid rgba(255,255,255,.1);
            border-radius: 12px;
            cursor: pointer;
            transition: all .2s;
            margin-bottom: .6rem;
            background: rgba(24,24,32,.4);
        }

            .create-tour-page .status-option:last-child {
                margin-bottom: 0;
            }

            .create-tour-page .status-option:hover {
                border-color: rgba(255,255,255,.15);
                background: rgba(255,255,255,.04);
            }

            .create-tour-page .status-option.selected-active {
                border-color: rgba(34,197,94,.5);
                background: rgba(34,197,94,.15);
            }

            .create-tour-page .status-option.selected-draft {
                border-color: rgba(251,191,36,.5);
                background: rgba(251,191,36,.12);
            }

            .create-tour-page .status-option input[type="radio"] {
                display: none;
            }

        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .dot-active {
            background: #16a34a;
        }

        .dot-draft {
            background: #d97706;
        }

        .dot-passive {
            background: #a0aec0;
        }

        .create-tour-page .status-text .stitle {
            font-size: .85rem;
            font-weight: 600;
            color: #ffffff;
        }

        .create-tour-page .status-text .ssub {
            font-size: .73rem;
            color: var(--text-muted);
        }


        .form-actions {
            display: flex;
            gap: .75rem;
            flex-direction: column;
        }

        .create-tour-page .btn-submit {
            background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%) !important;
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: .8rem 1.5rem;
            font-family: var(--font-display);
            font-weight: 700;
            font-size: .9rem;
            cursor: pointer;
            transition: all .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            width: 100%;
            box-shadow: 0 4px 16px rgba(56,189,248,.3);
        }

            .create-tour-page .btn-submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(56,189,248,.4) !important;
            }

        .create-tour-page .btn-draft {
            background: rgba(255,255,255,.06);
            color: #e2e8f0;
            border: 1px solid rgba(255,255,255,.12);
            border-radius: 12px;
            padding: .7rem 1.5rem;
            font-size: .875rem;
            font-weight: 500;
            cursor: pointer;
            transition: all .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            width: 100%;
            text-decoration: none;
        }

            .create-tour-page .btn-draft:hover {
                background: rgba(255,255,255,.1);
                border-color: rgba(255,255,255,.18);
                color: #fff;
            }

        .create-tour-page .btn-cancel {
            background: none;
            color: var(--text-muted);
            border: none;
            padding: .6rem;
            font-size: .8rem;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            display: block;
            transition: color .15s;
        }

            .create-tour-page .btn-cancel:hover {
                color: #94a3b8;
            }

        .create-tour-page .summary-box {
            background: rgba(24,24,32,.5);
            border: 1px solid rgba(255,255,255,.06);
            border-radius: 12px;
            padding: 1rem;
            font-size: .82rem;
        }

        .create-tour-page .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: .45rem 0;
            border-bottom: 1px solid rgba(255,255,255,.06);
            color: #e2e8f0;
        }

            .create-tour-page .summary-row:last-child {
                border-bottom: none;
            }

            .create-tour-page .summary-row .label {
                color: var(--text-muted);
            }

            .create-tour-page .summary-row .value {
                font-weight: 600;
                color: #ffffff;
            }


        .text-danger-field {
            font-size: .73rem;
            color: #e53e3e;
            margin-top: .35rem;
            display: flex;
            align-items: center;
            gap: .3rem;
        }

        @@media (max-width: 1199px) {
            .form-grid {
                grid-template-columns: 1fr 300px;
            }
        }

        @@media (max-width: 991px) {
            .form-grid {
                grid-template-columns: 1fr;
            }

            .sidebar-panel {
                position: static;
            }
        }

        .create-tour-page .page-title {
            color: #ffffff !important;
        }

        .create-tour-page .breadcrumb-item a {
            color: var(--accent-strong) !important;
        }

        .create-tour-page .breadcrumb-item.active {
            color: var(--text-muted) !important;
        }

        .create-tour-page .field-label {
            color: #e2e8f0 !important;
        }

            .create-tour-page .field-label .required {
                color: #f87171 !important;
            }

        .create-tour-page .field-hint {
            color: var(--text-muted) !important;
        }

        .create-tour-page .form-control,
        .create-tour-page .form-select {
            border-color: rgba(255,255,255,.1) !important;
            background: rgba(24,24,32,.7) !important;
            color: #ffffff !important;
        }

            .create-tour-page .form-control:focus,
            .create-tour-page .form-select:focus {
                border-color: var(--accent-strong) !important;
                box-shadow: 0 0 0 1px rgba(56,189,248,.3) !important;
            }

        .create-tour-page .input-with-icon .input-icon {
            color: var(--text-muted) !important;
        }

        .create-tour-page .char-counter {
            color: var(--text-muted) !important;
        }

            .create-tour-page .char-counter.warn {
                color: #fbbf24 !important;
            }

            .create-tour-page .char-counter.danger {
                color: #f87171 !important;
            }

        .create-tour-page .duration-unit label {
            color: var(--text-muted) !important;
        }

        .create-tour-page .stepper {
            border-color: rgba(255,255,255,.1) !important;
        }

        .create-tour-page .stepper-btn {
            background: rgba(255,255,255,.05) !important;
            color: #94a3b8 !important;
        }

            .create-tour-page .stepper-btn:hover {
                background: rgba(56,189,248,.15) !important;
                color: #38bdf8 !important;
            }

        .create-tour-page .stepper input {
            color: #ffffff !important;
            background: transparent !important;
        }

        .create-tour-page .status-option {
            border-color: rgba(255,255,255,.1) !important;
            background: rgba(24,24,32,.4) !important;
        }

            .create-tour-page .status-option:hover {
                border-color: rgba(255,255,255,.15) !important;
                background: rgba(255,255,255,.04) !important;
            }

            .create-tour-page .status-option.selected-active {
                border-color: rgba(34,197,94,.5) !important;
                background: rgba(34,197,94,.15) !important;
            }

            .create-tour-page .status-option.selected-draft {
                border-color: rgba(251,191,36,.5) !important;
                background: rgba(251,191,36,.12) !important;
            }

        .create-tour-page .status-text .stitle {
            color: #ffffff !important;
        }

        .create-tour-page .status-text .ssub {
            color: var(--text-muted) !important;
        }

        .create-tour-page .btn-submit {
            background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%) !important;
            box-shadow: 0 4px 16px rgba(56,189,248,.3);
        }

            .create-tour-page .btn-submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(56,189,248,.4) !important;
            }

        .create-tour-page .btn-draft {
            background: rgba(255,255,255,.06) !important;
            color: #e2e8f0 !important;
            border-color: rgba(255,255,255,.12) !important;
        }

            .create-tour-page .btn-draft:hover {
                background: rgba(255,255,255,.1) !important;
                color: #fff !important;
            }

        .create-tour-page .btn-cancel {
            color: var(--text-muted) !important;
        }

            .create-tour-page .btn-cancel:hover {
                color: #94a3b8 !important;
            }

        .create-tour-page .summary-box {
            background: rgba(24,24,32,.5) !important;
            border: 1px solid rgba(255,255,255,.06) !important;
        }

        .create-tour-page .summary-row {
            color: #e2e8f0 !important;
            border-bottom-color: rgba(255,255,255,.06) !important;
        }

            .create-tour-page .summary-row .label {
                color: var(--text-muted) !important;
            }

            .create-tour-page .summary-row .value {
                color: #ffffff !important;
            }

        .create-tour-page .text-danger-field {
            color: #f87171 !important;
        }

        .create-tour-page .d-flex.gap-3 div[style*="background"] {
            background: rgba(255,255,255,.08) !important;
        }

        .create-tour-page .d-flex.gap-3 span {
            color: var(--text-muted) !important;
        }

        .create-tour-page ul[style*="list-style"] li {
            color: var(--text-muted) !important;
        }

            .create-tour-page ul[style*="list-style"] li strong {
                color: #94a3b8 !important;
            }
    </style>
}

<!-- PAGE HEADER -->
<div class="create-tour-page">
    <div class="page-header">
        <div>
            <h1 class="page-title">Yeni Tur Ekle</h1>
            <nav aria-label="breadcrumb" class="mt-2">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="#">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="TourList">Turlar</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Yeni Tur</li>
                </ol>
            </nav>
        </div>
        <a asp-action="TourList" class="btn btn-outline-secondary d-flex align-items-center gap-2" style="border-radius:10px;font-size:.875rem;font-weight:500;padding:.55rem 1.1rem;">
            <i class="bi bi-arrow-left"></i> Tur Listesine Dön
        </a>
    </div>

    <form method="post" id="createTourForm" novalidate>

        <input type="hidden" asp-for="TourId" />
        <div class="form-grid">


            <div class="form-main">

                <div class="form-section">
                    <div class="section-header">
                        <div class="section-icon blue"><i class="bi bi-info-circle"></i></div>
                        <div>
                            <div class="section-title">Temel Bilgiler</div>
                            <div class="section-subtitle">Tur başlığı ve kısa açıklama</div>
                        </div>
                    </div>
                    <div class="section-body">

                        <div class="field-group">
                            <label asp-for="Title" class="field-label">
                                <i class="bi bi-tag" style="color:#a0aec0;font-size:.85rem;"></i>
                                Tur Başlığı <span class="required">*</span>
                            </label>
                            <input asp-for="Title" class="form-control" placeholder="örn: Kapadokya Balon Turu - 3 Gece 4 Gün" maxlength="120" id="tourTitleInput" />
                            <div class="char-counter" id="titleCounter">0 / 120</div>
                            <span asp-validation-for="Title" class="text-danger-field"><i class="bi bi-exclamation-circle"></i><span></span></span>
                        </div>


                        <div class="field-group">
                            <label asp-for="Description" class="field-label">
                                <i class="bi bi-text-left" style="color:#a0aec0;font-size:.85rem;"></i>
                                Açıklama <span class="required">*</span>
                            </label>
                            <textarea asp-for="Description" class="form-control" placeholder="Tur hakkında kısa bir açıklama yazın..." maxlength="1000" id="descInput" rows="5"></textarea>
                            <div class="char-counter" id="descCounter">0 / 1000</div>
                            <span asp-validation-for="Description" class="text-danger-field"><i class="bi bi-exclamation-circle"></i><span></span></span>
                        </div>
                    </div>
                </div>


                <div class="form-section">
                    <div class="section-header">
                        <div class="section-icon green"><i class="bi bi-geo-alt"></i></div>
                        <div>
                            <div class="section-title">Konum Bilgileri</div>
                            <div class="section-subtitle">Turun gideceği ülke ve şehir</div>
                        </div>
                    </div>
                    <div class="section-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="field-group">
                                    <label asp-for="Country" class="field-label">
                                        <i class="bi bi-globe2" style="color:#a0aec0;font-size:.85rem;"></i>
                                        Ülke <span class="required">*</span>
                                    </label>
                                    <div class="input-with-icon">
                                        <i class="bi bi-globe2 input-icon"></i>
                                        <select asp-for="Country" class="form-select" style="padding-left:2.4rem;" id="countrySelect">
                                            <option value="">Ülke seçin</option>
                                            <option value="Türkiye">Türkiye</option>
                                            <option value="Almanya">Almanya</option>
                                            <option value="İtalya">İtalya</option>
                                            <option value="Fransa">Fransa</option>
                                            <option value="İspanya">İspanya</option>
                                            <option value="Yunanistan">Yunanistan</option>
                                            <option value="Japonya">Japonya</option>
                                            <option value="Maldivler">Maldivler</option>
                                            <option value="Tayland">Tayland</option>
                                            <option value="Bali">Bali</option>
                                            <option value="Mısır">Mısır</option>
                                            <option value="Portekiz">Portekiz</option>
                                            <option value="Hırvatistan">Hırvatistan</option>
                                            <option value="Hollanda">Hollanda</option>
                                            <option value="Çekya">Çekya</option>
                                            <option value="Diğer">Diğer</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="Country" class="text-danger-field"><i class="bi bi-exclamation-circle"></i><span></span></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="field-group">
                                    <label asp-for="City" class="field-label">
                                        <i class="bi bi-building" style="color:#a0aec0;font-size:.85rem;"></i>
                                        Şehir <span class="required">*</span>
                                    </label>
                                    <div class="input-with-icon">
                                        <i class="bi bi-geo-alt input-icon"></i>
                                        <input asp-for="City" class="form-control" placeholder="örn: Nevşehir, Kapadokya" id="cityInput" />
                                    </div>
                                    <span asp-validation-for="City" class="text-danger-field"><i class="bi bi-exclamation-circle"></i><span></span></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TUR DETAYLARI -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-icon amber"><i class="bi bi-calendar3"></i></div>
                        <div>
                            <div class="section-title">Tur Detayları</div>
                            <div class="section-subtitle">Tarih, süre ve kapasite bilgileri</div>
                        </div>
                    </div>
                    <div class="section-body">
                        <div class="row g-3">
                            <!-- Tur Tarihi -->
                            <div class="col-md-6">
                                <div class="field-group">
                                    <label asp-for="TourDate" class="field-label">
                                        <i class="bi bi-calendar-event" style="color:#a0aec0;font-size:.85rem;"></i>
                                        Tur Tarihi <span class="required">*</span>
                                    </label>
                                    <div class="input-with-icon">
                                        <i class="bi bi-calendar3 input-icon"></i>
                                        <input asp-for="TourDate" type="date" class="form-control" id="tourDateInput"
                                               min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                    </div>
                                    <div class="field-hint"><i class="bi bi-info-circle me-1"></i>Bugünden önceki tarih seçilemez.</div>
                                    <span asp-validation-for="TourDate" class="text-danger-field"><i class="bi bi-exclamation-circle"></i><span></span></span>
                                </div>
                            </div>

                            <!-- Kapasite -->
                            <div class="col-md-6">
                                <div class="field-group">
                                    <label asp-for="Capacity" class="field-label">
                                        <i class="bi bi-people" style="color:#a0aec0;font-size:.85rem;"></i>
                                        Kapasite <span class="required">*</span>
                                    </label>

                                    <div class="stepper">
                                        <button type="button" class="stepper-btn" onclick="stepperDecrement()" aria-label="Azalt">
                                            <i class="bi bi-dash"></i>
                                        </button>
