@using Tripify.WebUI.Dtos.CommentDtos
@using Tripify.WebUI.Dtos.TourDtos
@{
    ViewData["Title"] = "TourDetail";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var tour = ViewBag.Tour as GetTourByIdDto;
    var tourDateFormatted = tour?.TourDate.ToString("d MMMM yyyy", System.Globalization.CultureInfo.CurrentUICulture) ?? "";
    var price = tour?.Price ?? 0;
    var capacity = tour?.Capacity > 0 ? tour.Capacity : 5;
}

<section class="breadcrumb-main pb-20 pt-14" style="background-image: url(/travelin/travelin/images/bg/paris.jpg);">
    <div class="section-shape section-shape1 top-inherit bottom-0" style="background-image: url(/travelin/travelin/images/shape8.png);"></div>
    <div class="breadcrumb-outer">
        <div class="container">
            <div class="breadcrumb-content text-center">
                <h1 class="mb-3">@Localizer["TourDetail_Title"]</h1>
                <nav aria-label="breadcrumb" class="d-block">
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/Default/Index/">@Localizer["TourDetail_Home"]</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@Localizer["TourDetail_Title"]</li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    <div class="dot-overlay"></div>
</section>


<section class="trending pt-6 pb-0 bg-lgrey">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="single-content">

                    @await Component.InvokeAsync("_TourDetailComponentPartial", new { tourId = ViewBag.TourId })


                    @await Component.InvokeAsync("_TourDetailWhatToExpectComponentPartial", new { tourId = ViewBag.TourId })


                    <div class="single-map mb-4">
                        <h4>@Localizer["TourDetail_Map"]</h4>
                        <div class="map rounded overflow-hidden" style="background:#f5f5f5;">
                            @if (!string.IsNullOrWhiteSpace(tour?.MapImageUrl))
                            {
                                <img src="@tour.MapImageUrl" alt="@Localizer["TourDetail_Map"]" class="w-100" style="max-height:600px;width:100%;object-fit:contain;object-position:top;display:block;" />
                            }
                            else
                            {
                                <div style="width: 100%">
                                    <iframe class="rounded overflow-hidden" height="400" src="https://maps.google.com/maps?width=100%25&amp;height=600&amp;hl=en&amp;q=+(mangal%20bazar)&amp;t=&amp;z=14&amp;ie=UTF8&amp;iwloc=B&amp;output=embed"></iframe>
                                </div>
                            }
                        </div>
                    </div>

                    @await Component.InvokeAsync("_TourDetailAverageCommentsComponentPartial", new { tourId = ViewBag.TourId })

                    @await Component.InvokeAsync("_TourDetailCommentListByTourComponentPartial", new { tourId = ViewBag.TourId })

                    @await Html.PartialAsync("/Views/Tour/MakeComment.cshtml", new CreateCommentDto { TourId = ViewBag.TourId })


                </div>
            </div>

            <div class="col-lg-4 ps-lg-4">
                <div class="sidebar-sticky">
                    <div class="list-sidebar">
                        <div class="sidebar-item">
                            <form class="form-content rounded overflow-hidden bg-title">
                                <h4 class="white text-center border-b pb-2">@Localizer["TourDetail_Booking"]</h4>
                                <div class="row">
                                    <div class="col-lg-12">
                                        <div class="form-group">
                                            <span class="white pb-1">@Localizer["TourDetail_ChooseDate"]</span>
                                            <h4 class="choosen-date white mb-0 border-0"><i class="fa fa-calendar"></i> @(string.IsNullOrEmpty(tourDateFormatted) ? "-" : tourDateFormatted) <small class="d-flex justify-content-between fw-normal w-100 my-2">@(string.IsNullOrEmpty(tour?.DayNight) ? "" : $"({tour.DayNight})") <a href="#" class="white text-decoration-underline">@Localizer["TourDetail_Change"]</a></small></h4>
                                        </div>
                                    </div>

                                    <div class="col-lg-12">
                                        <div class="form-group mb-2">
                                            <label class="white">@Localizer["TourDetail_NoOfPeople"]</label>
                                            <div class="input-box">
                                                <i class="flaticon-add-user"></i>
                                                <select class="niceSelect" id="bookingGuestCount" data-price="@price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">
                                                    @for (int i = 1; i <= capacity; i++)
                                                    {
                                                        <option value="@i">@i</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-lg-12">
                                        <div class="form-group bg-white p-3 rounded mb-2" id="bookingPriceBox">
                                            <ul>
                                                <li class="d-block pb-1"><span id="priceLine">@price.ToString("0.00") ₺ x <span id="guestCount">1</span></span><span class="float-end fw-bold" id="subtotalSpan">@price.ToString("0.00") ₺</span></li>
                                                <li class="d-block pb-1">Other fees<span class="float-end fw-bold">Free</span></li>
                                                <li class="d-block border-t">
                                                    <div class="pt-1">
                                                        <span class="fw-bold">Total</span><span class="float-end fw-bold" id="totalSpan">@price.ToString("0.00") ₺</span>
                                                    </div>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="col-lg-12">
                                        <div class="form-group mb-0">
                                            <a href="/Booking/Index?tourId=@ViewBag.TourId" class="nir-btn w-100" id="bookNowBtn">@Localizer["TourDetail_BookNow"]</a>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Component.InvokeAsync("_TourDetailVideoComponentPartial")

<div id="back-to-top">
    <a href="#"></a>
</div>

@section Scripts {
<script>
    $(function() {
        var $select = $('#bookingGuestCount');
        var $guestCount = $('#guestCount');
        var $subtotal = $('#subtotalSpan');
        var $total = $('#totalSpan');
        var $bookBtn = $('#bookNowBtn');
        var price = parseFloat($select.data('price')) || 0;
        var tourId = '@ViewBag.TourId';
        function updatePrice() {
            var count = parseInt($select.val()) || 1;
            var subtotal = price * count;
            $guestCount.text(count);
            $subtotal.text(subtotal.toFixed(2) + ' ₺');
            $total.text(subtotal.toFixed(2) + ' ₺');
            $bookBtn.attr('href', '/Booking/Index?tourId=' + tourId + '&people=' + count);
        }
        $select.on('change', updatePrice);
    });
</script>
}
