@model List<Tripify.WebUI.Dtos.AboutDtos.ResultAboutDto>
@{
    ViewData["Title"] = "Hakkımızda İçerikleri";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

<div class="page-header mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title h4 mb-1">Hakkımızda İçerikleri</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Hakkımızda</li>
            </ol>
        </nav>
    </div>
    <a href="/AdminAbout/CreateAbout" class="btn btn-primary d-flex align-items-center gap-2" style="border-radius:10px;">
        <i class="bi bi-plus-lg"></i> Yeni İçerik Ekle
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-info-circle text-secondary"></i>
            <span class="fw-semibold">Kayıtlı Hakkımızda İçerikleri</span>
            <span class="badge bg-light text-muted border">@Model?.Count ?? 0 kayıt</span>
        </div>
    </div>
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-4 text-center text-muted">
                <i class="bi bi-emoji-neutral mb-2" style="font-size:2rem;"></i>
                <p class="mb-1">Henüz kayıtlı bir içerik bulunmuyor.</p>
                <a href="/AdminAbout/CreateAbout" class="btn btn-sm btn-primary mt-2">İlk içeriği ekle</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Başlık</th>
                            <th>Açıklama</th>
                            <th>Neden Biz? (1)</th>
                            <th>Neden Biz? (2)</th>
                            <th>Neden Biz? (3)</th>
                            <th>Neden Biz? (4)</th>
                            <th style="width:120px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.Title</div>
                                </td>
                                <td>
                                    @{
                                        var desc = item.Description;
                                        if (!string.IsNullOrEmpty(desc) && desc.Length > 80)
                                        {
                                            desc = desc.Substring(0, 80) + "...";
                                        }
                                    }
                                    <span class="text-muted" style="font-size:.85rem;">@desc</span>
                                </td>
                                <td>
                                    <div class="small">
                                        <div class="fw-semibold">@item.WhyUsTitle</div>
                                        <div class="text-muted">@item.WhyUsDescription</div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small">
                                        <div class="fw-semibold">@item.WhyUsTitle2</div>
                                        <div class="text-muted">@item.WhyUsDescription2</div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small">
                                        <div class="fw-semibold">@item.WhyUsTitle3</div>
                                        <div class="text-muted">@item.WhyUsDescription3</div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small">
                                        <div class="fw-semibold">@item.WhyUsTitle4</div>
                                        <div class="text-muted">@item.WhyUsDescription4</div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="/AdminAbout/UpdateAbout/@item.AboutId" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a href="/AdminAbout/RemoveAbout/@item.AboutId" class="btn btn-sm btn-danger"
                                           onclick="return confirm('Bu içeriği silmek istediğinize emin misiniz?');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

