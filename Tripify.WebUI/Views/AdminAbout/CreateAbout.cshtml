@model Tripify.WebUI.Dtos.AboutDtos.CreateAboutDto
@{
    ViewData["Title"] = "Yeni Hakkımızda İçeriği";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

<div class="page-header mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title h4 mb-1">Yeni Hakkımızda İçeriği</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item"><a href="/AdminAbout/AboutList">Hakkımızda</a></li>
                <li class="breadcrumb-item active" aria-current="page">Yeni İçerik</li>
            </ol>
        </nav>
    </div>
    <a href="/AdminAbout/AboutList" class="btn btn-outline-secondary d-flex align-items-center gap-2" style="border-radius:10px;">
        <i class="bi bi-arrow-left"></i> Listeye Dön
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form method="post">

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold">Başlık</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-semibold">Açıklama</label>
                <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <h5 class="fw-bold mb-3">Neden Biz? Alanları</h5>

            <div class="row">
                <div class="col-md-6">
                    <div class="border rounded p-3 mb-3">
                        <div class="mb-2">
                            <label asp-for="WhyUsIconUrl" class="form-label">1. Icon URL</label>
                            <input asp-for="WhyUsIconUrl" class="form-control" />
                        </div>
                        <div class="mb-2">
                            <label asp-for="WhyUsTitle" class="form-label">1. Başlık</label>
                            <input asp-for="WhyUsTitle" class="form-control" />
                        </div>
                        <div class="mb-0">
                            <label asp-for="WhyUsDescription" class="form-label">1. Açıklama</label>
                            <textarea asp-for="WhyUsDescription" rows="2" class="form-control"></textarea>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="border rounded p-3 mb-3">
                        <div class="mb-2">
                            <label asp-for="WhyUsIconUrl2" class="form-label">2. Icon URL</label>
                            <input asp-for="WhyUsIconUrl2" class="form-control" />
                        </div>
                        <div class="mb-2">
                            <label asp-for="WhyUsTitle2" class="form-label">2. Başlık</label>
                            <input asp-for="WhyUsTitle2" class="form-control" />
                        </div>
                        <div class="mb-0">
                            <label asp-for="WhyUsDescription2" class="form-label">2. Açıklama</label>
                            <textarea asp-for="WhyUsDescription2" rows="2" class="form-control"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="border rounded p-3 mb-3">
                        <div class="mb-2">
                            <label asp-for="WhyUsIconUrl3" class="form-label">3. Icon URL</label>
                            <input asp-for="WhyUsIconUrl3" class="form-control" />
                        </div>
                        <div class="mb-2">
                            <label asp-for="WhyUsTitle3" class="form-label">3. Başlık</label>
                            <input asp-for="WhyUsTitle3" class="form-control" />
                        </div>
                        <div class="mb-0">
                            <label asp-for="WhyUsDescription3" class="form-label">3. Açıklama</label>
                            <textarea asp-for="WhyUsDescription3" rows="2" class="form-control"></textarea>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="border rounded p-3 mb-3">
                        <div class="mb-2">
                            <label asp-for="WhyUsIconUrl4" class="form-label">4. Icon URL</label>
                            <input asp-for="WhyUsIconUrl4" class="form-control" />
                        </div>
                        <div class="mb-2">
                            <label asp-for="WhyUsTitle4" class="form-label">4. Başlık</label>
                            <input asp-for="WhyUsTitle4" class="form-control" />
                        </div>
                        <div class="mb-0">
                            <label asp-for="WhyUsDescription4" class="form-label">4. Açıklama</label>
                            <textarea asp-for="WhyUsDescription4" rows="2" class="form-control"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <a href="/AdminAbout/AboutList" class="btn btn-outline-secondary">İptal</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

