@model List<ResultTestimonialDto>
<section class="testimonial pt-9" style="background-image: url(/travelin/travelin/images/testimonial.png)">
    <div class="container">
        <div class="section-title mb-6 text-center w-75 mx-auto">
            <h4 class="mb-1 theme1">Tur Yorumları</h4>
            <h2 class="mb-1">Misafirlermizin <span class="theme">Deneyimleri</span></h2>
            <p>Katılımcıların turlarımız hakkında yaptığı yorumlar.</p>
        </div>

        <div class="row align-items-center">
            <!-- Sol görsel -->
            <div class="col-lg-5 pe-4">
                <div class="testimonial-image">
                    <img src="/travelin/travelin/images/travel2.png" alt="Travel experience" />
                </div>
            </div>

            <!-- Yorumlar -->
            <div class="col-lg-7 ps-4">
                <div class="review-slider">

                    <!-- YORUM 1 -->
                    @foreach (var item in Model)
                    {
                        <div class="testimonial-item1 rounded">
                            <div class="author-info d-flex align-items-center mb-3">
                                <img src="@item.ImageUrl" alt="Kullanıcı" />
                                <div class="author-title ms-3">
                                    <h5 class="m-0 theme">@item.TestimonialName</h5>
                                    <span>@item.Title</span>
                                </div>
                            </div>

                            <div class="details">
                                <p class="m-0">
                                    <i class="fa fa-quote-left me-2 fs-1"></i>
                                    @item.Description
                                </p>
                                <div class="mt-2 text-warning">
                                    ★★★★☆
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>