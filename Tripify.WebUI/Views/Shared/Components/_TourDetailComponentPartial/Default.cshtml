@model GetTourByIdDto

@if (Model != null)
{
    <div class="single-full-title border-b mb-2 pb-2">
        <div class="single-title">
            <h2 class="mb-1">@Model.Title</h2>
            <div class="rating-main d-lg-flex align-items-center text-lg-start text-center">
                <p class="mb-0 me-2"><i class="icon-location-pin"></i> @Model.City, @Model.Country</p>
                <div class="rating me-2">
                    <span class="fa fa-star checked"></span>
                    <span class="fa fa-star checked"></span>
                    <span class="fa fa-star checked"></span>
                    <span class="fa fa-star checked"></span>
                    <span class="fa fa-star checked"></span>
                </div>
                <span>(@Model.Capacity Kişi Kapasiteli)</span>
            </div>
        </div>
    </div>
    <div class="description-images mb-4 overflow-hidden">
        <div class="thumbnail-images position-relative">
            <div class="slider-store rounded overflow-hidden">
                <div>
                    <img src="@Model.ImageUrl" alt="@Model.Title" style="width: 100%; height: 400px; object-fit: cover;">
                </div>
            </div>
        </div>
    </div>

    <div class="description mb-2">
        <h4>Açıklama</h4>
        <p>@Model.Description</p>
    </div>

    <div class="tour-includes mb-4">
        <table>
            <tbody>
                <tr>
                    <td><i class="fa fa-clock-o pink mr-1" aria-hidden="true"></i> @Model.DayNight</td>
                    <td><i class="fa fa-group pink mr-1" aria-hidden="true"></i> Maksimum Kişi: @Model.Capacity</td>
                    <td><i class="fa fa-tag pink mr-1" aria-hidden="true"></i> Fiyat: @Model.Price ₺</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="description mb-2">
        <div class="row">
            <div class="col-lg-6 col-md-6 mb-2">
                <div class="desc-box bg-grey p-4 rounded">
                    <h5 class="mb-2">Lokasyon</h5>
                    <p class="mb-0">@Model.City, @Model.Country</p>
                </div>
            </div>
            <div class="col-lg-6 col-md-6 mb-2">
                <div class="desc-box bg-grey p-4 rounded">
                    <h5 class="mb-2">Süre</h5>
                    <p class="mb-0">@Model.DayNight</p>
                </div>
            </div>
            <div class="col-lg-6 col-md-6 mb-2">
                <div class="desc-box bg-grey p-4 rounded">
                    <h5 class="mb-2">Kapasite</h5>
                    <p class="mb-0">@Model.Capacity Kişi</p>
                </div>
            </div>
            <div class="col-lg-6 col-md-6 mb-2">
                <div class="desc-box bg-grey p-4 rounded">
                    <h5 class="mb-2">Fiyat</h5>
                    <p class="mb-0">@Model.Price ₺ / Kişi</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">
        <p>Tur bilgisi bulunamadı.</p>
    </div>
}