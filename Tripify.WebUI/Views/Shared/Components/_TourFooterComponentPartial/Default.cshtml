                        <h3 class="white">@Localizer["Footer_Categories"]</h3>
                        <ul>
                            <li><a href="/Tour/TourList">@Localizer["Footer_DomesticTours"]</a></li>
                            <li><a href="/Tour/TourList">@Localizer["Footer_InternationalTours"]</a></li>
                            <li><a href="/Tour/TourList">@Localizer["Footer_CultureTours"]</a></li>
                            <li><a href="/Tour/TourList">@Localizer["Footer_NatureTours"]</a></li>
                            <li><a href="/Tour/TourList">@Localizer["Footer_DayTours"]</a></li>
                            <li><a href="/Tour/TourList">@Localizer["Footer_SpecialEvents"]</a></li>
