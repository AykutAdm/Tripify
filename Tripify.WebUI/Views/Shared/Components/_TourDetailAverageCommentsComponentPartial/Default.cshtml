@model Tripify.WebUI.ViewComponents.TourDetailViewComponents.CommentAverageViewModel

<div class="single-review mb-4">
    <h4>
        <i class="fa fa-star me-2" style="color: #FFD700;"></i>
        Ortalama Değerlendirmeler
    </h4>
    <div class="row d-flex align-items-center">
        <div class="col-lg-12 col-md-12">
            <div class="review-box position-relative rounded overflow-hidden" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <!-- AI Badge -->
                <div class="position-absolute top-0 end-0 m-3">
                    <span class="badge bg-white text-dark shadow-sm">
                        <i class="fa fa-robot me-1"></i>AI Analiz
                    </span>
                </div>

                <div class="text-center py-4 p-2">
                    <!-- Rating Score -->
                    <h2 class="mb-2 white">
                        <span class="display-3 fw-bold">@Model.AverageRating.ToString("0.0")</span>
                        <span class="fs-2">/5</span>
                    </h2>

                    <!-- Stars -->
                    <div class="mb-3">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor(Model.AverageRating))
                            {
                                <i class="fa fa-star" style="color: #FFD700; font-size: 24px;"></i>
                            }
                            else if (i - Model.AverageRating < 1)
                            {
                                <i class="fa fa-star-half-o" style="color: #FFD700; font-size: 24px;"></i>
                            }
                            else
                            {
                                <i class="fa fa-star-o" style="color: #FFD700; font-size: 24px;"></i>
                            }
                        }
                    </div>

                    <!-- AI Summary -->
                    <div class="ai-summary-box bg-white rounded p-3 mx-3 mb-3 shadow-sm">
                        <div class="d-flex align-items-start">
                            <i class="fa fa-quote-left me-2 mt-1" style="color: #667eea; font-size: 20px;"></i>
                            <p class="mb-0 font-italic" style="line-height: 1.6; color: #2c3e50;">
                                @Model.AISummary
                            </p>
                            <i class="fa fa-quote-right ms-2 mt-1" style="color: #667eea; font-size: 20px;"></i>
                        </div>
                    </div>

                    <!-- Total Reviews -->
                    <p class="mb-0 white opacity-75">
                        <i class="fa fa-comments me-2"></i>
                        @Model.TotalComments Misafir Yorumu Analiz Edildi
                    </p>
                </div>

                <!-- Decorative Elements -->
                <div class="position-absolute bottom-0 start-0 w-100" style="height: 4px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);"></div>
            </div>
        </div>
    </div>
</div>

<style>
    .ai-summary-box {
        animation: fadeInUp 0.8s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .review-box {
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        transition: transform 0.3s ease;
    }

        .review-box:hover {
            transform: translateY(-5px);
        }
</style>
