@model List<ResultLast4TourDto>

<section class="trending pb-0" style="background-image: url(~/images/shape-1.png); background-position: center">
    <div class="container">
        <div class="section-title mb-6 w-50 mx-auto text-center">
            <h4 class="mb-1 theme1">@Localizer["TopDest_Title"]</h4>
            <h2 class="mb-1">@Localizer["TopDest_Subtitle"]</h2>
            <p>@Localizer["TopDest_Desc"]</p>
        </div>
        <div class="row align-items-center">
            <div class="col-lg-12">
                <div class="row">
                    @foreach (var item in Model)
                    {
                        <div class="col-lg-3 col-md-6">
                            <div class="trend-item1 mb-3 mb-lg-0">
                                <div class="trend-image position-relative rounded">
                                    <img src="@item.ImageUrl" alt="image" href="/Tour/TourDetail/@item.TourId" style="height:320px;width:352px;" />
                                    <div class="trend-content d-flex align-items-end justify-content-between position-absolute bottom-0 p-3 w-100 z-index">
                                        <div class="trend-content-title">
                                            <h5 class="mb-0"><a href="/Tour/TourDetail/@item.TourId" class="theme1">@item.Country | @item.City</a></h5>
                                            <h3 class="mb-0 white" href="/Tour/TourDetail/@item.TourId">@item.Title</h3>
                                        </div>
                                    </div>
                                    <div class="color-overlay"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
<!-- top Destination ends -->
