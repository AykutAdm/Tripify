@model List<ResultGuideDto>
<section class="our-team pb-0 pt-6">
    <div class="container">
        <div class="section-title mb-6 w-75 mx-auto text-center">
            <h4 class="mb-1 theme1">Tur Rehberleri</h4>
            <h2 class="mb-1">Alanında Uzman <span class="theme">Rehberlerimiz</span></h2>
            <p>
                Tripify bünyesinde yer alan profesyonel tur rehberleri, seyahatiniz boyunca
                güvenli, bilgilendirici ve keyifli bir deneyim yaşamanız için hizmet vermektedir.
            </p>
        </div>
        <div class="team-main">
            <div class="row shop-slider">
                @foreach (var item in Model)
                {
                    <div class="col-lg-3 col-md-6 col-sm-12 mb-4">
                        <div class="team-list rounded">
                            <div class="team-image">
                                <img src="@item.ImageUrl" alt="rehber" style="width:352px; height:320px;" />
                            </div>
                            <div class="team-content text-center p-3 bg-theme">
                                <h4 class="mb-0 white">@item.GuideNameSurname</h4>
                                <p class="theme" style="color:darkolivegreen">@item.Title</p>
                                <p class="mb-0 white">@item.Description</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>