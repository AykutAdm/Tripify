@model Tripify.WebUI.Dtos.GuideDtos.CreateGuideDto
@{
    ViewData["Title"] = "Yeni Rehber";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

<div class="page-header mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title h4 mb-1">Yeni Rehber Ekle</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item"><a href="/AdminGuide/GuideList">Rehberler</a></li>
                <li class="breadcrumb-item active" aria-current="page">Yeni Rehber</li>
            </ol>
        </nav>
    </div>
    <a href="/AdminGuide/GuideList" class="btn btn-outline-secondary d-flex align-items-center gap-2" style="border-radius:10px;">
        <i class="bi bi-arrow-left"></i> Listeye Dön
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="GuideNameSurname" class="form-label fw-semibold">Ad Soyad</label>
                        <input asp-for="GuideNameSurname" class="form-control" />
                        <span asp-validation-for="GuideNameSurname" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">Ünvan / Başlık</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">Açıklama</label>
                <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label fw-semibold">Görsel URL</label>
                        <input asp-for="ImageUrl" class="form-control" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="TourId" class="form-label fw-semibold">Bağlı Olduğu Tur Id</label>
                        <input asp-for="TourId" class="form-control" />
                        <span asp-validation-for="TourId" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <a href="/AdminGuide/GuideList" class="btn btn-outline-secondary">İptal</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

