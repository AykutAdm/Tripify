@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
    var toursCount = ViewBag.ToursCount;
    var bookingsCount = ViewBag.BookingsCount;
    var commentsCount = ViewBag.CommentsCount;
    var testimonialsCount = ViewBag.TestimonialsCount;
    var guidesCount = ViewBag.GuidesCount;
    var recentTours = ViewBag.RecentTours as List<ResultTourDto>;
    var recentBookings = ViewBag.RecentBookings as List<ResultBookingDto>;
}

@section Styles {
<style>
    /* Zoom-friendly: rem/em units, antialiased text */
    html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; text-rendering: optimizeLegibility; }
    
    .dash-page {
        padding: 1.5rem 0 3rem;
        max-width: 1400px;
        margin: 0 auto;
    }
    
    .dash-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }
    
    .dash-title {
        font-family: var(--font-body);
        font-size: clamp(1.25rem, 2.5vw, 1.5rem);
        font-weight: 600;
        color: #f8fafc;
        letter-spacing: -0.02em;
        line-height: 1.3;
    }
    
    .dash-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    
    .dash-action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1rem;
        background: rgba(56, 189, 248, 0.15);
        color: #38bdf8;
        border: 1px solid rgba(56, 189, 248, 0.25);
        border-radius: 0.5rem;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: background 0.2s, border-color 0.2s;
    }
    .dash-action-btn:hover { background: rgba(56, 189, 248, 0.25); border-color: rgba(56, 189, 248, 0.4); color: #7dd3fc; }
    
    .stat-row {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }
    @@media (max-width: 1100px) { .stat-row { grid-template-columns: repeat(3, 1fr); } }
    @@media (max-width: 640px) { .stat-row { grid-template-columns: repeat(2, 1fr); } }
    
    .stat-card {
        background: rgba(18, 18, 28, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 1rem;
        padding: 1.25rem;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        transition: border-color 0.2s, transform 0.2s;
    }
    .stat-card:hover { border-color: rgba(255, 255, 255, 0.12); transform: translateY(-1px); }
    
    .stat-card .icon-wrap {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }
    .stat-card.blue .icon-wrap { background: rgba(56, 189, 248, 0.2); color: #38bdf8; }
    .stat-card.green .icon-wrap { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
    .stat-card.amber .icon-wrap { background: rgba(251, 191, 36, 0.2); color: #fbbf24; }
    .stat-card.purple .icon-wrap { background: rgba(168, 85, 247, 0.2); color: #a855f7; }
    .stat-card.pink .icon-wrap { background: rgba(236, 72, 153, 0.2); color: #ec4899; }
    
    .stat-card .content { min-width: 0; }
    .stat-card .value {
        font-family: var(--font-body);
        font-size: 1.5rem;
        font-weight: 700;
        color: #ffffff;
        line-height: 1.2;
        letter-spacing: -0.02em;
    }
    .stat-card .label {
        font-size: 0.8125rem;
        color: #94a3b8;
        margin-top: 0.25rem;
    }
    
    .content-grid {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 1.5rem;
        align-items: start;
    }
    @@media (max-width: 1024px) { .content-grid { grid-template-columns: 1fr; } }
    
    .dash-card {
        background: rgba(18, 18, 28, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 1rem;
        overflow: hidden;
    }
    
    .dash-card-header {
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(30, 30, 40, 0.5);
    }
    .dash-card-header .title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: #f1f5f9;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .dash-card-header .title i { color: #38bdf8; font-size: 1rem; }
    .dash-card-header .btn-link {
        font-size: 0.8125rem;
        color: #38bdf8;
        text-decoration: none;
        font-weight: 500;
    }
    .dash-card-header .btn-link:hover { color: #7dd3fc; text-decoration: underline; }
    
    .dash-table {
        width: 100%;
        border-collapse: collapse;
    }
    .dash-table th {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        padding: 0.875rem 1.25rem;
        text-align: left;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(15, 15, 22, 0.6);
    }
    .dash-table td {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        font-size: 0.875rem;
        color: #e2e8f0;
    }
    .dash-table tbody tr:last-child td { border-bottom: none; }
    .dash-table tbody tr:hover td { background: rgba(255, 255, 255, 0.02); }
    .dash-table .customer-name { font-weight: 600; color: #f8fafc; }
    .dash-table .customer-email { font-size: 0.8125rem; color: #94a3b8; margin-top: 0.125rem; }
    
    .status-pill {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        border-radius: 0.375rem;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .status-ok { background: rgba(34, 197, 94, 0.2); color: #4ade80; }
    .status-pending { background: rgba(251, 191, 36, 0.2); color: #fcd34d; }
    .status-reject { background: rgba(248, 113, 113, 0.2); color: #f87171; }
    
    .tour-list { padding: 0.5rem 0; }
    .tour-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        text-decoration: none;
        color: inherit;
        transition: background 0.15s;
    }
    .tour-item:hover { background: rgba(255, 255, 255, 0.03); }
    .tour-item:last-child { border-bottom: none; }
    .tour-item .thumb {
        width: 3.25rem;
        height: 3.25rem;
        border-radius: 0.5rem;
        object-fit: cover;
        background: rgba(30, 30, 40, 0.8);
        flex-shrink: 0;
    }
    .tour-item .thumb-placeholder {
        width: 3.25rem;
        height: 3.25rem;
        border-radius: 0.5rem;
        background: rgba(30, 30, 40, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        font-size: 1.125rem;
        flex-shrink: 0;
    }
    .tour-item .info { flex: 1; min-width: 0; }
    .tour-item .info .name { font-size: 0.875rem; font-weight: 600; color: #f8fafc; line-height: 1.4; }
    .tour-item .info .meta { font-size: 0.75rem; color: #94a3b8; margin-top: 0.25rem; }
    .tour-item .badge {
        font-size: 0.6875rem;
        padding: 0.25rem 0.5rem;
        border-radius: 0.375rem;
        background: rgba(56, 189, 248, 0.15);
        color: #38bdf8;
        font-weight: 600;
        flex-shrink: 0;
    }
    
    .empty-state {
        padding: 2.5rem 1.5rem;
        text-align: center;
        color: #64748b;
        font-size: 0.875rem;
    }
    .empty-state i { font-size: 2rem; margin-bottom: 0.5rem; display: block; opacity: 0.6; }
</style>
}

<div class="dash-page">
    <div class="dash-header">
        <h1 class="dash-title">Dashboard</h1>
        <div class="dash-actions">
            <a href="/AdminTour/TourList" class="dash-action-btn"><i class="bi bi-list-ul"></i> Turlar</a>
            <a href="/AdminTour/CreateTour" class="dash-action-btn"><i class="bi bi-plus-circle"></i> Yeni Tur</a>
            <a href="/AdminBooking/BookingList" class="dash-action-btn"><i class="bi bi-calendar2-check"></i> Rezervasyonlar</a>
        </div>
    </div>

    <div class="stat-row">
        <div class="stat-card blue">
            <div class="icon-wrap"><i class="bi bi-map"></i></div>
            <div class="content">
                <div class="value">@toursCount</div>
                <div class="label">Toplam Tur</div>
            </div>
        </div>
        <div class="stat-card green">
            <div class="icon-wrap"><i class="bi bi-calendar2-check"></i></div>
            <div class="content">
                <div class="value">@bookingsCount</div>
                <div class="label">Rezervasyon</div>
            </div>
        </div>
        <div class="stat-card amber">
            <div class="icon-wrap"><i class="bi bi-chat-dots"></i></div>
            <div class="content">
                <div class="value">@commentsCount</div>
                <div class="label">Yorum</div>
            </div>
        </div>
        <div class="stat-card purple">
            <div class="icon-wrap"><i class="bi bi-star"></i></div>
            <div class="content">
                <div class="value">@testimonialsCount</div>
                <div class="label">Referans</div>
            </div>
        </div>
        <div class="stat-card pink">
            <div class="icon-wrap"><i class="bi bi-person-badge"></i></div>
            <div class="content">
                <div class="value">@guidesCount</div>
                <div class="label">Rehber</div>
            </div>
        </div>
    </div>

    <div class="content-grid">
        <div class="dash-card">
            <div class="dash-card-header">
                <span class="title"><i class="bi bi-calendar2-event"></i> Son Rezervasyonlar</span>
                <a href="/AdminBooking/BookingList" class="btn-link">Tümünü gör →</a>
            </div>
            @if (recentBookings.Count > 0)
            {
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Müşteri</th>
                            <th>Tarih</th>
                            <th>Kişi</th>
                            <th>Tutar</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in recentBookings)
                        {
                            <tr>
                                <td>
                                    <div class="customer-name">@item.FirstName @item.LastName</div>
                                    <div class="customer-email">@item.Email</div>
                                </td>
                                <td>@item.BookingDate.ToString("dd.MM.yyyy")</td>
                                <td>@item.NumberOfPeople</td>
                                <td>@item.TotalPrice.ToString("N2") ₺</td>
                                <td>
                                    @if (item.Status == "Approved") { <span class="status-pill status-ok">Onaylandı</span> }
                                    else if (item.Status == "Rejected") { <span class="status-pill status-reject">Reddedildi</span> }
                                    else { <span class="status-pill status-pending">Beklemede</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state"><i class="bi bi-inbox"></i> Henüz rezervasyon yok</div>
            }
        </div>

        <div class="dash-card">
            <div class="dash-card-header">
                <span class="title"><i class="bi bi-map"></i> Son Eklenen Turlar</span>
                <a href="/AdminTour/TourList" class="btn-link">Tümünü gör →</a>
            </div>
            @if (recentTours.Count > 0)
            {
                <div class="tour-list">
                    @foreach (var item in recentTours)
                    {
                        <a href="/AdminTour/UpdateTour/@item.TourId" class="tour-item">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Title" class="thumb" />
                            }
                            else
                            {
                                <div class="thumb-placeholder"><i class="bi bi-image"></i></div>
                            }
                            <div class="info">
                                <div class="name">@item.Title</div>
                                <div class="meta">@item.City, @item.Country · @item.TourDate.ToString("dd.MM.yyyy")</div>
                            </div>
                            <span class="badge">@item.DayNight</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="empty-state"><i class="bi bi-map"></i> Henüz tur eklenmemiş</div>
            }
        </div>
    </div>
</div>
