@model List<ResultCommentDto>
@{
    ViewData["Title"] = "Yorumlar";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

<div class="page-header mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title h4 mb-1">Yorum Listesi</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Yorumlar</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-chat-dots text-secondary"></i>
            <span class="fw-semibold">Kayıtlı Yorumlar</span>
            <span class="badge bg-light text-muted border">@Model?.Count ?? 0 kayıt</span>
        </div>
    </div>
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-4 text-center text-muted">
                <i class="bi bi-emoji-frown mb-2" style="font-size:2rem;"></i>
                <p class="mb-1">Henüz kayıtlı bir yorum bulunmuyor.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tur Id</th>
                            <th>Ad Soyad</th>
                            <th>Başlık</th>
                            <th>Puan</th>
                            <th>Tarih</th>
                            <th>Durum</th>
                            <th style="width:150px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderByDescending(x => x.CommentDate))
                        {
                            <tr>
                                <td>@item.TourId</td>
                                <td>@item.NameSurname</td>
                                <td>
                                    <div class="fw-semibold">@item.Headline</div>
                                    <div class="text-muted small">
                                        @((item.CommentDetail?.Length > 60) ? item.CommentDetail.Substring(0, 60) + "..." : item.CommentDetail)
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-star-fill me-1"></i>@item.Score
                                    </span>
                                </td>
                                <td>@item.CommentDate.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (item.IsStatus)
                                    {
                                        <span class="badge bg-success-subtle text-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Pasif</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <form asp-action="ToggleStatus" asp-controller="AdminComment" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.CommentId" />
                                            <input type="hidden" name="isActive" value="@(!item.IsStatus)" />
                                            <button type="submit" class="btn btn-sm @(item.IsStatus ? "btn-outline-secondary" : "btn-success")" title="Durum Değiştir">
                                                @if (item.IsStatus)
                                                {
                                                    <i class="bi bi-eye-slash"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-eye"></i>
                                                }
                                            </button>
                                        </form>
                                        <a href="/AdminComment/RemoveComment/@item.CommentId" class="btn btn-sm btn-danger"
                                           onclick="return confirm('Bu yorumu silmek istediğinize emin misiniz?');">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

