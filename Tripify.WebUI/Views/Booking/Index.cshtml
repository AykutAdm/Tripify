@model CreateBookingDto
@{
    ViewData["Title"] = "Rezervasyon Yap";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var tour = ViewBag.Tour as Tripify.WebUI.Dtos.TourDtos.GetTourByIdDto;
}

<section class="breadcrumb-main pb-20 pt-14" style="background-image: url(/travelin/travelin/images/bg/paris.jpg);">
    <div class="section-shape section-shape1 top-inherit bottom-0" style="background-image: url(/travelin/travelin/images/shape8.png);"></div>
    <div class="breadcrumb-outer">
        <div class="container">
            <div class="breadcrumb-content text-center">
                <h1 class="mb-3">Rezervasyon</h1>
                <nav aria-label="breadcrumb" class="d-block">
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/Default/Index">Ana Sayfa</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Rezervasyon</li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    <div class="dot-overlay"></div>
</section>

<section class="trending pt-6 pb-0 bg-lgrey">
    <div class="container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="payment-book">
                    <div class="booking-box">
                        <div class="customer-information mb-4">
                            <h3 class="border-b pb-2 mb-2">Rezervasyon Bilgileri</h3>
                            <form method="post" asp-controller="Booking" asp-action="CreateBooking" class="mb-2">
                                <input type="hidden" asp-for="TourId" value="@ViewBag.TourId" />
                                <input type="hidden" asp-for="Status" value="Pending" />

                                <h5>Kişisel Bilgileriniz</h5>
                                <div class="row">
                                    <div class="col-md-2">
                                        <div class="form-group mb-2">
                                            <label>Ünvan</label>
                                            <div class="input-box">
                                                <select asp-for="Title" class="form-control">
                                                    <option value="">Seçin</option>
                                                    <option value="Bay">Bay</option>
                                                    <option value="Bayan">Bayan</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-5">
                                        <div class="form-group mb-2">
                                            <label>Ad</label>
                                            <input type="text" asp-for="FirstName" class="form-control" placeholder="Adınız" required>
                                        </div>
                                    </div>
                                    <div class="col-md-5">
                                        <div class="form-group mb-2">
                                            <label>Soyad</label>
                                            <input type="text" asp-for="LastName" class="form-control" placeholder="Soyadınız" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group mb-2">
                                            <label>E-posta</label>
                                            <input type="email" asp-for="Email" class="form-control" placeholder="E-posta Adresiniz" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group mb-2">
                                            <label>Telefon</label>
                                            <input type="text" asp-for="Phone" class="form-control" placeholder="Telefon No." required>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-sm-6">
                                        <div class="form-group mb-2">
                                            <label>Cinsiyet</label>
                                            <div class="input-box">
                                                <select asp-for="Gender" class="form-control">
                                                    <option value="">Cinsiyet Seçin</option>
                                                    <option value="Erkek">Erkek</option>
                                                    <option value="Kadın">Kadın</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-sm-6">
                                        <div class="form-group mb-2">
                                            <label>Doğum Tarihi</label>
                                            <div class="input-box">
                                                <input asp-for="DateOfBirth" type="date" class="form-control" required>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-sm-12">
                                        <div class="form-group mb-2">
                                            <label>Ülke</label>
                                            <div class="input-box">
                                                <input type="text" asp-for="Country" class="form-control" placeholder="Ülke" required>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-sm-12">
                                        <div class="form-group mb-2">
                                            <label>Şehir</label>
                                            <div class="input-box">
                                                <input type="text" asp-for="City" class="form-control" placeholder="Şehir" required>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group mb-2">
                                            <label>Adres Satırı 1</label>
                                            <input type="text" asp-for="AddressLine1" class="form-control" placeholder="Adres 1" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group mb-2">
                                            <label>Adres Satırı 2</label>
                                            <input type="text" asp-for="AddressLine2" class="form-control" placeholder="Adres 2">
                                        </div>
                                    </div>

                                    <h5 class="mt-3">Tur Bilgileri</h5>
                                    <div class="col-md-4">
                                        <div class="form-group mb-2">
                                            <label>Giriş Tarihi</label>
                                            <input type="date" asp-for="CheckInDate" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group mb-2">
                                            <label>Çıkış Tarihi</label>
                                            <input type="date" asp-for="CheckOutDate" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group mb-2">
                                            <label>Kişi Sayısı</label>
                                            <input type="number" id="numberOfPeople" asp-for="NumberOfPeople" class="form-control" min="1" value="1" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group mb-2">
                                            <label>Toplam Fiyat (Tur fiyatı x Kişi sayısı)</label>
                                            <input type="number" id="totalPrice" asp-for="TotalPrice" class="form-control" step="0.01" readonly style="background: #e9ecef;">
                                        </div>
                                    </div>
                                </div>

                                <div class="row mt-4">
                                    <div class="col-12">
                                        <button type="submit" class="nir-btn w-100 py-3">
                                            <i class="fa fa-check me-2"></i>
                                            Rezervasyonu Tamamla
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4 ps-ld-4">
                <div class="sidebar-sticky">
                    <div class="sidebar-item bg-white rounded box-shadow overflow-hidden p-3 mb-4">
                        <h4>Rezervasyon Detayları</h4>
                        @if (tour != null)
                        {
                            <div class="trend-full border-b pb-2 mb-2">
                                <div class="row">
                                    <div class="col-lg-4 col-md-4">
                                        <div class="trend-item2 rounded">
                                            <a href="#" style="background-image: url(@tour.ImageUrl);"></a>
                                            <div class="color-overlay"></div>
                                        </div>
                                    </div>
                                    <div class="col-lg-8 col-md-8 ps-0">
                                        <div class="trend-content position-relative">
                                            <h5 class="mb-1">@tour.Title</h5>
                                            <h6 class="theme mb-0"><i class="icon-location-pin"></i> @tour.Country</h6>
                                            <p class="mb-0 mt-2"><strong>Fiyat:</strong> @tour.Price TL</p>
                                            <p class="mb-0"><strong>Süre:</strong> @tour.DayNight</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="customer-information d-flex align-items-center bg-grey rounded p-4">
                            <i class="fa fa-info-circle rounded fs-1 bg-theme white p-3 px-4"></i>
                            <div class="customer-info ps-4">
                                <h6 class="mb-1">Bilgi:</h6>
                                <small>Rezervasyonunuz onaylandıktan sonra e-posta ile bilgilendirileceksiniz.</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div id="back-to-top">
    <a href="#"></a>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var tourPrice = @(tour?.Price ?? 0);
        var peopleInput = document.getElementById('numberOfPeople');
        var totalInput = document.getElementById('totalPrice');

        function updateTotal() {
            var people = parseInt(peopleInput.value) || 1;
            totalInput.value = (tourPrice * people).toFixed(2);
        }

        if (peopleInput && totalInput) {
            updateTotal();
            peopleInput.addEventListener('input', updateTotal);
            peopleInput.addEventListener('change', updateTotal);
        }
    });
</script>
